# Get this from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Where booking requests and contact messages are sent
BUSINESS_EMAIL=eliteautocare10@icloud.com

# Must be on a domain you've verified inside Resend before going live.
# Until you verify a domain, Resend only lets you send from onboarding@resend.dev
# to your own account email — fine for testing, not for real customers.
RESEND_FROM_EMAIL="Elite Autocare <bookings@yourdomain.co.uk>"

# Postgres connection string for the bookings database. In Vercel, add the
# Neon integration under Storage → Create → Postgres — this env var gets
# populated automatically for you (locally, copy the connection string it
# gives you into .env.local).
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# A random secret so only Vercel Cron (not the public internet) can trigger
# the review-email job. Generate one with `openssl rand -hex 32` and add the
# same value in Vercel's environment variables.
CRON_SECRET=change-me-to-a-random-string

# Link customers click to leave a Google review. Defaults to Elite Autocare's
# review link if unset.
GOOGLE_REVIEW_URL=https://g.page/r/CR9jW1DER_QgEBM/review
